{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "packageRules": [
        {
            "matchCategories": ["docker"],
            "groupName": "all docker dependencies"
        },
        {
            // single dep with commitMessageExtra
            "matchPackageNames": ["lodash"],
            "commitMessageExtra": "(new lodash)"
        },
        {
            // single group dep with commitMessageExtra
            "matchPackageNames": ["commander"],
            "groupName": "commander group",
            "commitMessageExtra": "(new commander)"
        }
    ]
}